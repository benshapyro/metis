# Auth.js v5
  AUTH_SECRET=
  APP_PASSWORD=

  # Vercel-managed — pulled via `vercel env pull .env.local`
  POSTGRES_URL=
  DATABASE_URL=
  POSTGRES_URL_NON_POOLING=
  POSTGRES_PRISMA_URL=
  PGDATABASE=
  PGHOST=
  PGUSER=
  PGPASSWORD=

  # Upstash Redis
  REDIS_URL=
  KV_URL=
  KV_REST_API_URL=
  KV_REST_API_TOKEN=
  KV_REST_API_READ_ONLY_TOKEN=

  # Vercel AI Gateway (auto on Vercel; set only for non-Vercel deploys)
  AI_GATEWAY_API_KEY=
  VERCEL_OIDC_TOKEN=

  # Runtime
  WIKI_ROOT=./wiki/wiki
  NEXT_PUBLIC_BASE_PATH=